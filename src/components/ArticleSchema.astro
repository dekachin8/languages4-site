---
interface Props {
  headline: string;
  description?: string;
  image?: string;
  datePublished: Date;
  dateModified?: Date;
  author?: string;
  url: string;
  keywords?: string[];
  articleSection?: string;
}

const {
  headline,
  description,
  image,
  datePublished,
  dateModified,
  author = 'Languages 4 Team',
  url,
  keywords,
  articleSection,
} = Astro.props;

const SITE = 'https://www.languages4.com';
const absoluteUrl = url.startsWith('http') ? url : `${SITE}${url}`;
const absoluteImage = image
  ? (image.startsWith('http') ? image : `${SITE}${image}`)
  : undefined;

const schema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline,
  url: absoluteUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': absoluteUrl },
  datePublished: datePublished.toISOString(),
  dateModified: (dateModified || datePublished).toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'Languages 4',
    logo: {
      '@type': 'ImageObject',
      url: `${SITE}/images/logo.png`,
    },
  },
};

if (description) schema.description = description;
if (absoluteImage) schema.image = absoluteImage;
if (keywords && keywords.length) schema.keywords = keywords.join(', ');
if (articleSection) schema.articleSection = articleSection;
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
