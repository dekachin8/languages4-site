---
// TableOfContents.astro - Auto-generates TOC from article headings
interface Props {
  content: string; // Raw markdown content
}

const { content } = Astro.props;

// Extract headings from markdown
interface Heading {
  level: number;
  text: string;
  id: string;
}

// Strip markdown formatting delimiters so the TOC displays clean text
// instead of raw `**bold**` / `\-escaped` syntax from heading source.
function stripMarkdown(text: string): string {
  return text
    .replace(/\*\*([^*]+)\*\*/g, '$1') // **bold**
    .replace(/\*([^*]+)\*/g, '$1')     // *italic*
    .replace(/`([^`]+)`/g, '$1')       // `code`
    .replace(/\\(.)/g, '$1');          // \X → X
}

function extractHeadings(markdown: string): Heading[] {
  const headingRegex = /^(#{2})\s+(.+)$/gm; // Only H2 headings
  const headings: Heading[] = [];
  let match;

  while ((match = headingRegex.exec(markdown)) !== null) {
    const level = match[1].length;
    const rawText = match[2].trim();
    const text = stripMarkdown(rawText);
    // IDs derived from rawText to preserve legacy anchor behavior
    // (rehypeSlug-generated heading IDs follow the raw text, not the
    // cleaned display text).
    const id = rawText
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-');

    headings.push({ level, text, id });
  }

  return headings;
}

const headings = extractHeadings(content);
---

{headings.length > 0 && (
  <div class="bg-white rounded-lg p-6 shadow-md border border-neutral-200">
    <h2 class="font-display text-2xl font-bold text-primary-900 mb-6 pb-3 border-b-2 border-primary-900">
      Table of Contents
    </h2>
    
    <nav class="max-h-96 overflow-y-auto pr-2">
      <ul class="space-y-3">
        {headings.map(heading => (
          <li>
            <a 
              href={`#${heading.id}`}
              class="text-accent-600 hover:text-accent-700 hover:underline transition-colors leading-snug block text-sm font-medium"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}