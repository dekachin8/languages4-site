---
// SchemaOrg.astro - Organization + SoftwareApplication structured data
// Renders across every page via MainLayout

const SITE = 'https://www.languages4.com';

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Languages 4',
  legalName: 'Languages 4',
  url: SITE,
  logo: `${SITE}/images/logo.png`,
  description: 'Languages 4 partners with Indigenous communities to create custom language learning platforms. We specialize in affordable, fast, community-led language reclamation software.',
  foundingDate: '2023',
  founder: {
    '@type': 'Person',
    name: "Tim O'Hagan",
    jobTitle: 'Founder & President',
  },
  knowsAbout: [
    'Indigenous language revitalization',
    'Language sovereignty',
    'Custom language learning software',
    'Community-led language education',
    'Land-based curriculum',
    'Speech recognition technology',
    'Scaffolded immersion pedagogy',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-480-304-1378',
    contactType: 'Customer Service',
    email: 'info@languages4.com',
    areaServed: ['US', 'CA'],
    availableLanguage: ['English'],
  },
  sameAs: [
    'https://instagram.com/l4_languages4',
    'https://linkedin.com/company/languages4',
    'https://facebook.com/profile.php?id=100090258725077',
    'https://twitter.com/l4languages4',
    'https://tiktok.com/@l4_languages4',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Phoenix',
    addressRegion: 'AZ',
    addressCountry: 'US',
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(organization)} />
