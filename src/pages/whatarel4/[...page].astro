---
// src/pages/whatarel4/[...page].astro - Main blog with pagination and tag filtering
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import CollectionListingLayout from '../../layouts/CollectionListingLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { filterByTag, getAllTagsWithCounts } from '../../utils/tagFilter';
import { groupByYear } from '../../utils/archiveUtils';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection('whatarel4', ({ data }) => {
    return data.draft !== true;
  });

  const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  const allTagsWithCounts = getAllTagsWithCounts(sortedPosts);

  return paginate(sortedPosts, {
    pageSize: 12,
    props: {
      allTags: allTagsWithCounts,
      allPostsSorted: sortedPosts,
    },
  });
};

type Props = {
  page: Page<CollectionEntry<'whatarel4'>>;
  allTags: Array<{ tag: string; count: number }>;
  allPostsSorted: CollectionEntry<'whatarel4'>[];
};

const { page, allTags, allPostsSorted } = Astro.props as Props;

const activeTag = Astro.url.searchParams.get('tag');

const displayPosts = activeTag
  ? filterByTag(page.data, activeTag)
  : page.data;

// Split into Latest (4) + More (8 randomized) on page 1 with no tag filter
const showSections = page.currentPage === 1 && !activeTag;
const latestPosts = showSections ? allPostsSorted.slice(0, 4) : [];
const remainingPosts = showSections
  ? allPostsSorted.slice(4, 12).sort(() => Math.random() - 0.5)
  : displayPosts;

// Random selection of 3 popular posts (whatarel4-specific behavior)
const allPostsForSidebar = await getCollection('whatarel4', ({ data }) => data.draft !== true);
const shuffled = [...allPostsForSidebar].sort(() => Math.random() - 0.5);
const popularPosts = shuffled
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    slug: post.slug,
    heroImage: post.data.heroImage,
    collection: 'whatarel4' as const,
  }));

// Archive years (whatarel4-only)
const yearGroups = groupByYear(allPostsForSidebar);
const archiveYears = Array.from(yearGroups.entries())
  .map(([year, posts]) => ({ year, count: posts.length }))
  .sort((a, b) => b.year - a.year);

const pageTitle = activeTag
  ? `What Are Languages 4? - ${activeTag}`
  : 'What Are Languages 4?';

const pageDescription = activeTag
  ? `Articles about ${activeTag} - Indigenous language reclamation`
  : 'Explore articles about Indigenous language reclamation through storytelling and technology';

const infoBoxBody = activeTag
  ? `Discover articles about ${activeTag}. Click "Clear Filter" to see all articles.`
  : 'Discover stories of Indigenous language reclamation, innovative technology, and cultural preservation.';

const noResultsBody = `No articles match the tag "${activeTag}". Try a different tag or clear the filter.`;
---

<CollectionListingLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  collection="whatarel4"
  heroImage="/images/whatarel4/whatarel4-hero.webp"
  heroImageAlt="What Are Languages 4?"
  heroTitle="What Are Languages 4?"
  heroSubtitle="Revitalizing Indigenous Languages Through Storytelling and Ceremonial Practices"
  activeTag={activeTag}
  infoBoxTitle="Welcome to the Languages 4 Blog"
  infoBoxBody={infoBoxBody}
  displayCount={displayPosts.length}
  nounSingular="article"
  nounPlural="articles"
  noResultsTitle="No Articles Found"
  noResultsBody={noResultsBody}
  noResultsCtaText="View All Articles"
  basePath="/whatarel4"
  page={page}
  popularPosts={popularPosts}
  allTags={allTags}
  archiveYears={archiveYears}
>
  <!-- Articles Container with Scale Compensation -->
  <div class="scale-80 origin-top-left" style="width: 100%;">

    {(showSections && latestPosts.length > 0) && (
      <div class="mb-12">
        <h2 class="font-display text-2xl font-bold text-primary-900 mb-6">Latest Articles</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {latestPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              heroImageAlt={post.data.heroImageAlt}
              cardImage={post.data.cardImage}
              cardImageAlt={post.data.cardImageAlt}
              slug={post.slug}
              tags={post.data.tags}
              collection="whatarel4"
            />
          ))}
        </div>
      </div>
    )}

    {remainingPosts.length > 0 && (
      <div class="mb-3">
        {showSections && <h2 class="font-display text-2xl font-bold text-primary-900 mb-6">More Articles</h2>}
        <div class="grid md:grid-cols-2 gap-6">
          {remainingPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              heroImageAlt={post.data.heroImageAlt}
              cardImage={post.data.cardImage}
              cardImageAlt={post.data.cardImageAlt}
              slug={post.slug}
              tags={post.data.tags}
              collection="whatarel4"
            />
          ))}
        </div>
      </div>
    )}

  </div>
</CollectionListingLayout>
