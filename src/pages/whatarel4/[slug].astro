---
// src/pages/whatarel4/[slug].astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CollectionArticleLayout from '../../layouts/CollectionArticleLayout.astro';
import { getAllTagsWithCounts } from '../../utils/tagFilter';

export async function getStaticPaths() {
  const blogPosts = await getCollection('whatarel4', ({ data }) => {
    return data.draft !== true;
  });

  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'whatarel4'>;
};

const { post } = Astro.props as Props;

const allPosts = await getCollection('whatarel4', ({ data }) => data.draft !== true);

// Random selection of 3 popular posts (whatarel4-specific behavior)
const shuffled = [...allPosts].sort(() => Math.random() - 0.5);
const popularPosts = shuffled
  .slice(0, 3)
  .map((p) => ({
    title: p.data.title,
    slug: p.slug,
    heroImage: p.data.heroImage,
    collection: 'whatarel4' as const,
  }));

const allTagsWithCounts = getAllTagsWithCounts(allPosts);

// Gallery: cardImage + any additional gallery images (whatarel4-specific combining)
const allGalleryImages: { src: string; alt: string; caption?: string }[] = [];
if (post.data.cardImage) {
  allGalleryImages.push({
    src: post.data.cardImage,
    alt: post.data.cardImageAlt || post.data.title,
  });
}
if (post.data.galleryImages && post.data.galleryImages.length > 0) {
  allGalleryImages.push(...post.data.galleryImages);
}
---

<CollectionArticleLayout
  post={post}
  collection="whatarel4"
  collectionLabel="What Are L4"
  collectionUrl="/whatarel4/"
  tagLinkBase="/whatarel4?tag="
  eyebrow="What Are L4 · Indigenous Language Reclamation"
  articleSection="What Are L4"
  backLinkText="Back to All Articles"
  popularPosts={popularPosts}
  allTagsWithCounts={allTagsWithCounts}
  galleryImages={allGalleryImages}
  proseClass="prose prose-lg max-w-full"
/>
