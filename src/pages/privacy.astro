---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Privacy Policy"
  description="Languages 4 Privacy Policy — how we collect, use, and protect your information."
>

<section class="relative py-20 md:py-32 bg-white">
  <div class="container mx-auto px-4 md:px-8 lg:pr-24 max-w-3xl">
    <h1 class="font-display text-4xl md:text-5xl font-medium text-primary-900 mb-6">
      Privacy Policy
    </h1>
    <p class="text-neutral-700 text-sm mb-12">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>

    <div class="prose prose-lg max-w-none text-neutral-700">
      <p class="text-lg text-neutral-600 italic border-l-4 border-accent-600 pl-4 mb-12">
        Our full Privacy Policy is being finalized and will be published here shortly.
        If you have questions about how Languages 4 handles your data, please contact us at
        <a href="mailto:info@languages4.com" class="text-accent-600 hover:underline">info@languages4.com</a>.
      </p>
    </div>

    <a
      href="/contact"
      class="inline-flex items-center gap-2 py-3 px-6 bg-accent-600 text-white rounded-lg font-semibold transition-all duration-300 hover:bg-accent-700 hover:-translate-y-0.5"
    >
      Contact Us
    </a>
  </div>
</section>

</MainLayout>
