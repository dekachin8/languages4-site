---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Thank You — Languages 4"
  description="Your message has been received. We'll respond within 1 business day."
>

<section class="py-20 md:py-32 bg-gradient-to-b from-white to-neutral-50 min-h-[60vh] flex items-center">
  <div class="max-w-2xl mx-auto px-4 text-center">

    <div class="bg-white rounded-2xl shadow-xl p-10 md:p-14">
      <!-- Success icon -->
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-accent-100 text-accent-700 mb-8" aria-hidden="true">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-bold text-primary-900 mb-4">
        Thank you — your message is on its way.
      </h1>

      <p class="text-lg text-neutral-700 mb-8">
        We've received your inquiry and will respond within one business day to schedule your free consultation.
        In the meantime, feel free to explore our articles and Signature Collections.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-block py-3 px-8 bg-accent-600 text-white rounded-lg font-bold transition-all duration-300 hover:bg-accent-700"
        >
          Return to Home
        </a>
        <a
          href="/whatarel4/"
          class="inline-block py-3 px-8 border-2 border-primary-600 text-primary-600 rounded-lg font-bold transition-all duration-300 hover:bg-primary-600 hover:text-white"
        >
          Read Articles
        </a>
      </div>
    </div>

  </div>
</section>

</MainLayout>
