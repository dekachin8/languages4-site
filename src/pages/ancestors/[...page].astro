---
// src/pages/ancestors/[...page].astro - Ancestor profiles with pagination and tag filtering
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import CollectionListingLayout from '../../layouts/CollectionListingLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { filterByTag, getAllTagsWithCounts } from '../../utils/tagFilter';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allProfiles = await getCollection('ancestors', ({ data }) => {
    return data.draft !== true;
  });

  const sortedProfiles = allProfiles.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  const allTagsWithCounts = getAllTagsWithCounts(sortedProfiles);

  return paginate(sortedProfiles, {
    pageSize: 12,
    props: {
      allTags: allTagsWithCounts,
    },
  });
};

type Props = {
  page: Page<CollectionEntry<'ancestors'>>;
  allTags: Array<{ tag: string; count: number }>;
};

const { page, allTags } = Astro.props as Props;

const activeTag = Astro.url.searchParams.get('tag');

const displayProfiles = activeTag
  ? filterByTag(page.data, activeTag)
  : page.data;

const allProfilesForSidebar = await getCollection('ancestors', ({ data }) => data.draft !== true);
const popularProfiles = allProfilesForSidebar
  .filter((post) => post.data.featured)
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    slug: post.slug,
    heroImage: post.data.heroImage,
    collection: 'ancestors' as const,
  }));

const pageTitle = activeTag
  ? `Indigenous Ancestors - ${activeTag}`
  : 'Indigenous Ancestors';

const pageDescription = activeTag
  ? `Profiles of Indigenous leaders and language keepers - ${activeTag}`
  : 'Honoring Indigenous leaders, language keepers, and cultural champions who shaped language reclamation';

const infoBoxBody = activeTag
  ? `Discover profiles of Indigenous leaders related to ${activeTag}. Click "Clear Filter" to see all profiles.`
  : 'Explore profiles of Indigenous leaders, language keepers, and cultural champions who have shaped language reclamation movements.';

const noResultsBody = `No profiles match the tag "${activeTag}". Try a different tag or clear the filter.`;
---

<CollectionListingLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  collection="ancestors"
  heroImage="/images/ancestors/ancestors-hero.webp"
  heroImageAlt="Indigenous Ancestors"
  heroTitle="Languages 4 Generations | Indigenous Ancestors"
  heroSubtitle="Honoring Indigenous Leaders and Language Keepers"
  activeTag={activeTag}
  infoBoxTitle="Welcome to Indigenous Ancestors"
  infoBoxBody={infoBoxBody}
  displayCount={displayProfiles.length}
  nounSingular="profile"
  nounPlural="profiles"
  noResultsTitle="No Profiles Found"
  noResultsBody={noResultsBody}
  noResultsCtaText="View All Profiles"
  basePath="/ancestors"
  page={page}
  popularPosts={popularProfiles}
  allTags={allTags}
>
  {displayProfiles.length > 0 && (
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      {displayProfiles.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          heroImageAlt={post.data.heroImageAlt}
          cardImage={post.data.cardImage}
          cardImageAlt={post.data.cardImageAlt}
          slug={post.slug}
          author={post.data.author}
          tags={post.data.tags}
          collection="ancestors"
          ancestorName={post.data.ancestorName}
          tribe={post.data.tribe}
          lifespan={post.data.lifespan}
        />
      ))}
    </div>
  )}
</CollectionListingLayout>
