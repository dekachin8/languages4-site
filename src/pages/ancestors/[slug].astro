---
// src/pages/ancestors/[slug].astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CollectionArticleLayout from '../../layouts/CollectionArticleLayout.astro';
import { getAllTagsWithCounts } from '../../utils/tagFilter';

export async function getStaticPaths() {
  const ancestorProfiles = await getCollection('ancestors', ({ data }) => {
    return data.draft !== true;
  });

  return ancestorProfiles.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'ancestors'>;
};

const { post } = Astro.props as Props;

const allProfiles = await getCollection('ancestors', ({ data }) => data.draft !== true);
const popularPosts = allProfiles
  .filter((p) => p.data.featured)
  .slice(0, 3)
  .map((p) => ({
    title: p.data.title,
    slug: p.slug,
    heroImage: p.data.heroImage,
    collection: 'ancestors' as const,
  }));

const allTagsWithCounts = getAllTagsWithCounts(allProfiles);

// Gallery only shown when 3+ images are supplied (collection convention)
const galleryImages =
  post.data.galleryImages && post.data.galleryImages.length >= 3
    ? post.data.galleryImages
    : [];

const eyebrow = `Languages 4 Generations · Indigenous Ancestors${post.data.ancestorName ? ` · ${post.data.ancestorName}` : ''}`;

const proseClass = [
  'prose prose-lg max-w-none',
  'prose-headings:font-display prose-headings:text-primary-900',
  'prose-p:text-neutral-700 prose-p:leading-relaxed',
  'prose-a:text-accent-600 prose-a:font-semibold hover:prose-a:text-accent-700',
  'prose-strong:text-primary-900 prose-strong:font-bold',
  'prose-img:rounded-xl prose-img:shadow-lg',
].join(' ');
---

<CollectionArticleLayout
  post={post}
  collection="ancestors"
  collectionLabel="Indigenous Ancestors"
  collectionUrl="/ancestors/"
  tagLinkBase="/ancestors?tag="
  eyebrow={eyebrow}
  articleSection="Indigenous Ancestors"
  backLinkText="Back to All Profiles"
  popularPosts={popularPosts}
  allTagsWithCounts={allTagsWithCounts}
  galleryImages={galleryImages}
  proseClass={proseClass}
  dateLabel="Published "
>
  {(post.data.tribe || post.data.lifespan) && (
    <div slot="pre-content" class="bg-accent-50 rounded-lg p-6 mb-8">
      <div class="grid md:grid-cols-2 gap-4">
        {post.data.tribe && (
          <div>
            <h3 class="text-sm font-bold text-neutral-500 uppercase mb-1">Nation/Tribe</h3>
            <p class="text-lg font-semibold text-primary-900">{post.data.tribe}</p>
          </div>
        )}
        {post.data.lifespan && (
          <div>
            <h3 class="text-sm font-bold text-neutral-500 uppercase mb-1">Lifespan</h3>
            <p class="text-lg font-semibold text-primary-900">{post.data.lifespan}</p>
          </div>
        )}
      </div>
    </div>
  )}
</CollectionArticleLayout>
