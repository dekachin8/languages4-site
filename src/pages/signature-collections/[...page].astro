---
// src/pages/signature-collections/[...page].astro - Collections with pagination and tag filtering
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import CollectionListingLayout from '../../layouts/CollectionListingLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { filterByTag, getAllTagsWithCounts } from '../../utils/tagFilter';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allCollections = await getCollection('signature-collections', ({ data }) => {
    return data.draft !== true;
  });

  // Sort by series title, then by order within series
  const sortedCollections = allCollections.sort((a, b) => {
    const seriesCompare = (a.data.seriesTitle || '').localeCompare(b.data.seriesTitle || '');
    if (seriesCompare !== 0) return seriesCompare;
    return (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0);
  });

  const allTagsWithCounts = getAllTagsWithCounts(sortedCollections);

  return paginate(sortedCollections, {
    pageSize: 12,
    props: {
      allTags: allTagsWithCounts,
    },
  });
};

type Props = {
  page: Page<CollectionEntry<'signature-collections'>>;
  allTags: Array<{ tag: string; count: number }>;
};

const { page, allTags } = Astro.props as Props;

const activeTag = Astro.url.searchParams.get('tag');

const displayCollections = activeTag
  ? filterByTag(page.data, activeTag)
  : page.data;

const allCollectionsForSidebar = await getCollection('signature-collections', ({ data }) => data.draft !== true);
const popularCollections = allCollectionsForSidebar
  .filter((post) => post.data.featured)
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    slug: post.slug,
    heroImage: post.data.heroImage,
    collection: 'signature-collections' as const,
  }));

const pageTitle = activeTag
  ? `Signature Collections - ${activeTag}`
  : 'Signature Collections';

const pageDescription = activeTag
  ? `Multi-part series about ${activeTag} - Deep dives into Indigenous language reclamation`
  : 'In-depth multi-part series exploring Indigenous language reclamation, technology, and cultural practices';

const infoBoxBody = activeTag
  ? `Explore multi-part series about ${activeTag}. Click "Clear Filter" to see all series.`
  : 'Explore comprehensive multi-part series diving deep into specific topics in Indigenous language preservation.';

const noResultsBody = `No series match the tag "${activeTag}". Try a different tag or clear the filter.`;
---

<CollectionListingLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  collection="signature-collections"
  heroImage="/images/signature-collections/signature-collections-hero.webp"
  heroImageAlt="Signature Collections"
  heroTitle="Signature Collections"
  heroSubtitle="In-Depth Multi-Part Series on Indigenous Language Reclamation"
  activeTag={activeTag}
  infoBoxTitle="Welcome to Signature Collections"
  infoBoxBody={infoBoxBody}
  displayCount={displayCollections.length}
  nounSingular="article"
  nounPlural="articles"
  noResultsTitle="No Series Found"
  noResultsBody={noResultsBody}
  noResultsCtaText="View All Series"
  basePath="/signature-collections"
  page={page}
  popularPosts={popularCollections}
  allTags={allTags}
>
  {displayCollections.length > 0 && (
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      {displayCollections.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          heroImageAlt={post.data.heroImageAlt}
          cardImage={post.data.cardImage}
          cardImageAlt={post.data.cardImageAlt}
          slug={post.slug}
          author={post.data.author}
          tags={post.data.tags}
          collection="signature-collections"
          seriesTitle={post.data.seriesTitle}
          seriesOrder={post.data.seriesOrder}
        />
      ))}
    </div>
  )}
</CollectionListingLayout>
