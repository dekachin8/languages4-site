---
// Shared layout for listing pages (whatarel4, signature-collections,
// ancestors [...page].astro). The parent supplies all text, the
// pre-filtered card grid (via default slot), and the `page` object;
// this layout owns the hero, info box, results count, no-results
// message, pagination, and sidebar.

import type { Page } from 'astro';
import MainLayout from './MainLayout.astro';
import Sidebar from '../components/Sidebar.astro';

type ArticleCollection = 'whatarel4' | 'signature-collections' | 'ancestors';

type PopularArticle = {
  title: string;
  slug: string;
  heroImage?: string;
  collection: ArticleCollection;
};

type TagCount = { tag: string; count: number };

type ArchiveYear = { year: number; count: number };

export interface Props {
  pageTitle: string;
  pageDescription: string;
  collection: ArticleCollection;

  heroImage: string;
  heroImageAlt: string;
  heroTitle: string;
  heroSubtitle: string;

  activeTag: string | null;
  infoBoxTitle: string;
  infoBoxBody: string;

  displayCount: number;
  nounSingular: string;          // e.g. "article" / "profile"
  nounPlural: string;            // e.g. "articles" / "profiles"

  noResultsTitle: string;
  noResultsBody: string;
  noResultsCtaText: string;

  basePath: string;              // e.g. "/whatarel4" — drives pagination + no-results CTA

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  page: Page<any>;

  popularPosts: PopularArticle[];
  allTags: TagCount[];
  archiveYears?: ArchiveYear[];
}

const {
  pageTitle,
  pageDescription,
  collection,
  heroImage,
  heroImageAlt,
  heroTitle,
  heroSubtitle,
  activeTag,
  infoBoxTitle,
  infoBoxBody,
  displayCount,
  nounSingular,
  nounPlural,
  noResultsTitle,
  noResultsBody,
  noResultsCtaText,
  basePath,
  page,
  popularPosts,
  allTags,
  archiveYears,
} = Astro.props;
---

<MainLayout title={pageTitle} description={pageDescription}>

<!-- Hero Section -->
<section class="relative min-h-[40vh] flex items-center justify-center overflow-hidden lg:pr-20 xl:pr-24">
  <div class="absolute inset-0 z-0">
    <img
      src={heroImage}
      alt={heroImageAlt}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-primary-900/70"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-8 py-16 text-center">
    <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4 leading-tight border-b-4 border-white pb-4 inline-block">
      {heroTitle}
    </h1>
    <p class="text-xl md:text-2xl text-white uppercase tracking-wide leading-relaxed font-semibold mt-6">
      {heroSubtitle}
    </p>
    {activeTag && (
      <p class="text-lg text-accent-400 mt-4 font-semibold">
        Filtered by: {activeTag}
      </p>
    )}
  </div>
</section>

<!-- Main Content -->
<section class="bg-neutral-50 py-12 lg:pr-20 xl:pr-24">
  <div class="max-w-7xl mx-auto px-8">

    <!-- Info Box -->
    <div class="bg-white rounded-lg p-6 shadow-md border-l-4 border-accent-600 mb-8">
      <h2 class="font-display text-2xl font-bold text-primary-900 mb-2">{infoBoxTitle}</h2>
      <p class="text-neutral-700 leading-relaxed">{infoBoxBody}</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-12">

      <!-- Main Content (2 columns) -->
      <div class="lg:col-span-2">

        <!-- Results Count -->
        {activeTag && (
          <div class="mb-6 text-neutral-600">
            <p class="font-semibold">
              {displayCount} {displayCount === 1 ? nounSingular : nounPlural} found
            </p>
          </div>
        )}

        <slot />

        <!-- No Results Message -->
        {displayCount === 0 && (
          <div class="bg-white rounded-lg p-12 text-center shadow-md">
            <svg class="w-16 h-16 mx-auto text-neutral-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="font-display text-2xl font-bold text-neutral-700 mb-2">{noResultsTitle}</h3>
            <p class="text-neutral-600 mb-6">{noResultsBody}</p>
            <a
              href={basePath}
              class="inline-block px-6 py-3 bg-accent-600 text-white font-semibold rounded-lg hover:bg-accent-700 transition-colors"
            >
              {noResultsCtaText}
            </a>
          </div>
        )}

        <!-- Pagination -->
        {!activeTag && displayCount > 0 && (page.lastPage > 1) && (
          <nav class="flex justify-center items-center gap-2" aria-label="Pagination">
            {page.url.prev && (
              <a
                href={page.url.prev}
                class="px-4 py-2 bg-white border-2 border-neutral-300 text-neutral-700 rounded-lg hover:border-accent-600 hover:text-accent-600 transition-colors font-semibold"
              >
                ← Previous
              </a>
            )}

            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
              <a
                href={pageNum === 1 ? basePath : `${basePath}/${pageNum}`}
                class:list={[
                  "px-4 py-2 rounded-lg font-semibold transition-colors",
                  pageNum === page.currentPage
                    ? "bg-accent-600 text-white"
                    : "bg-white border-2 border-neutral-300 text-neutral-700 hover:border-accent-600 hover:text-accent-600"
                ]}
                aria-current={pageNum === page.currentPage ? 'page' : undefined}
              >
                {pageNum}
              </a>
            ))}

            {page.url.next && (
              <a
                href={page.url.next}
                class="px-4 py-2 bg-white border-2 border-neutral-300 text-neutral-700 rounded-lg hover:border-accent-600 hover:text-accent-600 transition-colors font-semibold"
              >
                Next →
              </a>
            )}
          </nav>
        )}

      </div>

      <!-- Sidebar (1 column) -->
      <div class="lg:col-span-1">
        <Sidebar
          popularArticles={popularPosts}
          tags={allTags}
          collection={collection}
          archiveYears={archiveYears}
        />
      </div>

    </div>

  </div>
</section>

</MainLayout>
